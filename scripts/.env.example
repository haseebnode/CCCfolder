# Smartlead API Configuration
# Copy this file to .env and fill in your actual API key

# Your Smartlead API key
# Get it from: https://app.smartlead.ai/app/settings/integrations
SMARTLEAD_API_KEY=your_api_key_here

# API Base URL (usually don't need to change)
SMARTLEAD_API_URL=https://server.smartlead.ai/api/v1
